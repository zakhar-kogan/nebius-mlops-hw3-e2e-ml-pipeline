# Inference credentials used by mini-swe-agent.
NEBIUS_API_KEY=XXX

# Pipeline runtime image used by DockerOperator and docker compose.
PIPELINE_IMAGE=mlops-assignment-pipeline:latest
HOST_PROJECT_ROOT=/home/zakhar/nebius-mlops-hw3-e2e-ml-pipeline
PIPELINE_DOCKER_NETWORK=mlops-pipeline

# MLflow tracking server. Use http://mlflow:5000 inside docker compose.
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=coding-agent-evals

# Optional S3-compatible Object Storage upload. Leave S3_BUCKET empty to disable uploads.
# For Cloudflare R2, use endpoint https://<account-id>.r2.cloudflarestorage.com and region auto.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=https://storage.eu-north1.nebius.cloud
AWS_DEFAULT_REGION=eu-north1
S3_BUCKET=
S3_PREFIX=mlops-assignment-runs

# Local service ports.
MLFLOW_PORT=5000
AIRFLOW_PORT=8080
